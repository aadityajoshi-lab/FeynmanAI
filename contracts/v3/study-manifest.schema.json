{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feynman.local/contracts/v3/study-manifest.schema.json",
  "title": "Feynman Study Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["studyPlanId", "sourceIds", "chapterSelection", "providerMode", "sourcePackVersion", "recordVersion", "outline", "scenes"],
  "properties": {
    "studyPlanId": { "type": "string", "minLength": 8, "maxLength": 120 },
    "sourceIds": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "string" } },
    "chapterSelection": { "type": "string", "enum": ["chapter_1", "all"] },
    "providerMode": { "type": "string", "enum": ["codex_fixture", "live_openai", "live_fireworks", "human_review"] },
    "sourcePackVersion": { "type": "string", "minLength": 1, "maxLength": 120 },
    "recordVersion": { "type": "integer", "minimum": 1 },
    "outline": {
      "type": "array", "minItems": 1, "maxItems": 12,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["conceptId", "title", "objective", "sourceAnchorIds"],
        "properties": {
          "conceptId": { "type": "string", "minLength": 1, "maxLength": 120 },
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "objective": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "sourceAnchorIds": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "string" } }
        }
      }
    },
    "scenes": {
      "type": "array", "minItems": 1, "maxItems": 40,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["sceneId", "conceptId", "type", "title", "sourceAnchorIds"],
        "properties": {
          "sceneId": { "type": "string", "minLength": 1, "maxLength": 120 },
          "conceptId": { "type": "string", "minLength": 1, "maxLength": 120 },
          "type": { "type": "string", "enum": ["whiteboard", "two_d", "three_d", "predict_checkpoint", "retrieval", "teach_back", "exam_bridge", "question_bank"] },
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "sourceAnchorIds": { "type": "array", "items": { "type": "string" }, "maxItems": 8 },
          "actions": { "type": "array", "maxItems": 40, "items": { "$ref": "#/$defs/action" } },
          "config": { "type": "object", "additionalProperties": true }
        }
      }
    }
  },
  "$defs": {
    "action": {
      "type": "object", "additionalProperties": false,
      "required": ["actionId", "kind"],
      "properties": {
        "actionId": { "type": "string", "maxLength": 120 },
        "kind": { "type": "string", "enum": ["reveal", "spotlight", "draw", "write", "equation", "pause"] },
        "label": { "type": "string", "maxLength": 240 },
        "payload": { "type": "object", "additionalProperties": true },
        "durationMs": { "type": "integer", "minimum": 0, "maximum": 120000 }
      }
    }
  }
}
