{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feynman-ai.local/contracts/v1/revision-request.schema.json",
  "title": "Claim revision request",
  "type": "object",
  "additionalProperties": false,
  "required": ["learnerRepair", "expectedVersion"],
  "properties": {
    "learnerRepair": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "expectedVersion": { "$ref": "common.schema.json#/$defs/recordVersion" },
    "clientRequestId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{8,100}$" }
  }
}
