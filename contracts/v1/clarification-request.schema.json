{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feynman-ai.local/contracts/v1/clarification-request.schema.json",
  "title": "Claim clarification request",
  "type": "object",
  "additionalProperties": false,
  "required": ["question", "recordVersion"],
  "properties": {
    "question": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "recordVersion": { "$ref": "common.schema.json#/$defs/recordVersion" }
  }
}
