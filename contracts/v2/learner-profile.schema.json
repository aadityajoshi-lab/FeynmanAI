{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feynman-ai.local/contracts/v2/learner-profile.schema.json",
  "title": "Learner profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["learnerId", "preferences", "subjectStates", "consent"],
  "properties": {
    "learnerId": { "type": "string", "minLength": 1 },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "explanationDepth": { "type": "string", "enum": ["starter", "standard", "deep"] },
        "pace": { "type": "string", "enum": ["gentle", "standard", "fast"] },
        "language": { "type": "string", "minLength": 2 },
        "selectedModes": { "type": "array", "items": { "type": "string" } },
        "reducedMotion": { "type": "boolean" }
      }
    },
    "subjectStates": { "type": "object", "additionalProperties": { "$ref": "#/definitions/subjectState" } },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rememberPreferences"],
      "properties": {
        "rememberPreferences": { "type": "boolean" },
        "rememberSkillEvidence": { "type": "boolean" }
      }
    }
  },
  "definitions": {
    "subjectState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills": { "type": "object", "additionalProperties": { "$ref": "#/definitions/skillState" } },
        "lastSeenAt": { "type": "string", "format": "date-time" }
      }
    },
    "skillState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "attemptCount", "uncertainty"],
      "properties": {
        "status": { "type": "string", "enum": ["unseen", "emerging", "practiced", "transfer_ready", "needs_review", "insufficient_evidence"] },
        "attemptCount": { "type": "integer", "minimum": 0 },
        "predictionAccuracy": { "type": "number", "minimum": 0, "maximum": 1 },
        "explanationQuality": { "type": "number", "minimum": 0, "maximum": 1 },
        "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
        "recommendedMode": { "type": "string" },
        "nextReviewAt": { "type": ["string", "null"], "format": "date-time" }
      }
    }
  }
}
