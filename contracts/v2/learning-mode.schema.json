{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feynman-ai.local/contracts/v2/learning-mode.schema.json",
  "title": "Learning mode",
  "type": "object",
  "additionalProperties": false,
  "required": ["modeId", "title", "description", "useWhen", "evidenceStrength"],
  "properties": {
    "modeId": { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "useWhen": { "type": "string", "minLength": 1 },
    "evidenceStrength": { "type": "string", "enum": ["strong", "moderate", "design_support"] },
    "steps": { "type": "array", "items": { "type": "string" } }
  }
}
