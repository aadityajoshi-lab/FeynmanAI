# Local browser origins allowed to use the session-backed API.
# Replace these with your deployed frontend URL(s) when hosting the backend.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Clerk server-side verification. Keep the secret key out of frontend files.
CLERK_SECRET_KEY=
# Optional base64-encoded Clerk public JWT verification key for local use.
# Do not place a Clerk secret key in this field.
CLERK_JWT_KEY_B64=
CLERK_AUTHORIZED_PARTIES=http://127.0.0.1:3000,http://localhost:3000

# Server-side provider configuration. Keep every key out of frontend files.
LLM_PROVIDER=openai
OPENAI_API_KEY=
# Optional OpenAI-compatible base URL for a self-hosted gateway.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.6-terra-high
OPENAI_TIMEOUT_SECONDS=240

MISTRAL_API_KEY=
MISTRAL_OCR_URL=https://api.mistral.ai/v1/ocr
MISTRAL_OCR_MODEL=mistral-ocr-4-0
MISTRAL_OCR_TIMEOUT_SECONDS=120
WEB_SOURCE_TIMEOUT_SECONDS=30
WEB_SOURCE_MAX_BYTES=26214400
