# Backend
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=feynman-dev-only-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# OpenAI Responses API configuration (server-side only).
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5.6-terra-high
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=240

# Notebook OCR (optional; local extraction is used when this is empty)
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-4-0
MISTRAL_OCR_URL=https://api.mistral.ai/v1/ocr
MISTRAL_OCR_TIMEOUT_SECONDS=180

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
