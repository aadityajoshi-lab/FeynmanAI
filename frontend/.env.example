# Remediation slides are generated by Django with the existing Fireworks Qwen key.
# The browser never receives the Fireworks credential.

# Optional narration. This is the same OpenMAIC VoxCPM Python API contract.
# Use the base URL of the FastAPI service; it must expose POST /tts/upload.
# Fireworks supplies the slide lesson; this local service supplies narration.
REMEDIATION_VOICE_BASE_URL=
TTS_VOXCPM_BASE_URL=
REMEDIATION_VOICE_API_KEY=
REMEDIATION_VOICE_PROMPT=natural, clear engineering classroom voice
REMEDIATION_VOICE_CFG_VALUE=2.0
REMEDIATION_VOICE_INFERENCE_TIMESTEPS=10
REMEDIATION_VOICE_NORMALIZE=false
REMEDIATION_VOICE_DENOISE=false
